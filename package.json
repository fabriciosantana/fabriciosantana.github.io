{
  "name": "fabriciosantana.github.io",
  "version": "1.0.0",
  "private": true,
  "description": "Fabricio Santana personal site and newsletter workflow",
  "scripts": {
    "install:all": "npm --prefix site install && npm --prefix newsletter-workflow install",
    "start": "npm --prefix site start",
    "build": "npm --prefix site run build",
    "build-gh": "npm --prefix site run build-gh",
    "deploy": "npm --prefix site run deploy",
    "newsletter:auth:gmail": "npm --prefix newsletter-workflow run auth:gmail",
    "newsletter:digest": "npm --prefix newsletter-workflow run digest",
    "newsletter:inspect:grafana": "npm --prefix newsletter-workflow run inspect:grafana",
    "newsletter:inspect:gmail": "npm --prefix newsletter-workflow run inspect:gmail",
    "newsletter:inspect:links": "npm --prefix newsletter-workflow run inspect:links",
    "newsletter:inspect:redirects": "npm --prefix newsletter-workflow run inspect:redirects",
    "newsletter:typecheck": "npm --prefix newsletter-workflow run typecheck"
  },
  "author": "Fabricio Santana",
  "license": "ISC"
}
